# Inference service (Docker/K8s: set these in env or --env-file)
HTTP_HOST=0.0.0.0
HTTP_PORT=9000
# 是否启用 Redis 与后台 Worker；设为 false 时不连接 Redis、不启动 Worker，仅用 POST /api/test/inference
ENABLE_REDIS=true
REDIS_URL=redis://115.190.242.159:30379/1
TASK_QUEUE=panorama:task
RESULT_QUEUE=panorama:result
INFERENCE_TIMEOUT_SECONDS=600
PROJECT_ROOT=/app
WEIGHTS_DIR=/app/weights
OUTPUTS_DIR=/app/outputs
LOG_LEVEL=INFO
HF_HOME=./cache/huggingface
OMP_NUM_THREADS=8

# 阿里云 OSS（可选；不配置则不上传 pano.png，仅本地落盘）
# 从阿里云控制台获取：Bucket 概览 -> Endpoint、RAM 用户 AccessKey
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
# 自定义域名或公网访问地址，用于返回可访问 URL（可选）
# OSS_BUCKET_DOMAIN=https://your-cdn.example.com
